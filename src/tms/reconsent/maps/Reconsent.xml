<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="tms.reconsent.maps.ReconsentMapper">
	
	<update id="updatePoolPrivYn" parameterType="map">
		UPDATE EVA_POOL_M
	 	SET	 	
		 	PRIV_YN 	= 'Y'	 	
			, PRIV_DTTM = sysdate
		WHERE 
	 		DI 	= #{di}
	</update>
	
	
		
		
</mapper>