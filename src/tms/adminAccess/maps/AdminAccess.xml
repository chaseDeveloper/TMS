		<select id="getAdminAccessList" parameterType="map" resultType="map">
		    SELECT
		        HIS_NO,
		        RMRK,
		        UNIV_NM,
		        TO_CHAR(INPT_DT, 'YYYY-MM-DD HH24:MI') AS INPT_DT
		    FROM EVA_HIS
		    WHERE PRIVACY_YN = 'Y'
		      <if test="sMultiSearchStr == 'true'">
		          AND RMRK LIKE '%리스트%'
		      </if>
		    ORDER BY INPT_DT DESC
		</select>

		
		<select id="getSubjectEmail" parameterType="map" resultType="map" flushCache="false">
			SELECT
				USR_ID
			FROM EVA_POOL_M
			WHERE NAME = #{name}
		</select>	
	</mapper>