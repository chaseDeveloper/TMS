    <resource>
        <data-source>
            <database>
                <vendor>oracle</vendor>
                <export-name>TEACH</export-name>
                <data-source-class-name>oracle.jdbc.pool.OracleConnectionPoolDataSource</data-source-class-name>
                <data-source-type>ConnectionPoolDataSource</data-source-type>
                <data-source-name>oracle.jdbc.pool.OracleConnectionPoolDataSource</data-source-name>
                <database-name>necte</database-name>
                <port-number>1521</port-number>
                <server-name>210.107.249.186</server-name>
                <user>eva_third</user>
                <password>didtjdvudrk512</password>
                <property>
                    <name>DriverType</name>
                    <type>java.lang.String</type>
                    <value>thin</value>
                </property>
                <connection-pool>
                    <pooling>
                        <min>5</min>
                        <max>50</max>
                        <step>5</step>
                        <period>3600000</period>
                    </pooling>
                    <wait-free-connection>
                        <enable-wait>true</enable-wait>
                        <wait-time>30000</wait-time>
                    </wait-free-connection>
                    <check-query>select 1 from dual</check-query>
                    <check-query-period>30000</check-query-period>
                </connection-pool>
                <auto-commit>true</auto-commit>
                <stmt-query-timeout>300000</stmt-query-timeout>
            </database>
