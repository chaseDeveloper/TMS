<?xml version="1.0" encoding="utf-8"?>
<jeus-system xmlns="http://www.tmaxsoft.com/xml/ns/jeus" version="6.0">
    <node>
        <name>necte</name>
        <class-ftp>true</class-ftp>
        <sequential-start>true</sequential-start>
        <enable-webadmin>true</enable-webadmin>

        <engine-container>
            <name>container1</name>
            <command-option>
                -Xms1024m -Xmx2048m -XX:MaxPermSize=128m
                -Xbootclasspath/p:/usr/tmax/jennifer45/agent/lwst.jdk.jar:/usr/tmax/jennifer45/agent/lwst.boot.jar
                -Djennifer.config=/usr/tmax/jennifer45/agent/nec.conf -javaagent:/usr/tmax/jennifer45/agent/misc/lwst.javaagent2.jar
            </command-option>
            <sequential-start>true</sequential-start>
            <engine-command>
                 <type>servlet</type>
                 <name>engine1</name>
            </engine-command>
            <system-logging>
                <level>INFO</level>
                <handler>
                    <file-handler>
                        <name>fileHandler</name>
                        <valid-day>1</valid-day>
                        <buffer-size>0</buffer-size>
                    </file-handler>
                </handler>
            </system-logging>
        </engine-container>

        <engine-container>
            <name>container2</name>
                <command-option>
                    -Xms1024m -Xmx2048m -XX:MaxPermSize=128m
                </command-option>
            <sequential-start>true</sequential-start>
            <engine-command>
                 <type>servlet</type>
                 <name>engine2</name>
            </engine-command>
            <system-logging>
                <level>INFO</level>
                <handler>
                    <file-handler>
                        <name>fileHandler</name>
                        <valid-day>1</valid-day>
                        <buffer-size>0</buffer-size>
                    </file-handler>
                </handler>
            </system-logging>
        </engine-container>
